# Copy this file to .env, then paste YOUR OWN keys. .env is gitignored, never commit keys.

# Blitz API — sources your target list (TAM). Used by scripts/source_leads.py.
# Create a key (free credits to start): https://app.blitz-api.ai  ·  docs: https://docs.blitz-api.ai
BLITZAPI_API_KEY=

# lemlist — sends your multichannel campaign (LinkedIn + email). Used by scripts/push_to_lemlist.py.
# Create a key: lemlist -> Settings -> Integrations -> API  ·  docs: https://developer.lemlist.com
LEMLIST_API_KEY=

# Optional, only if you want to verify emails yourself:
# KITT_API_KEY=
